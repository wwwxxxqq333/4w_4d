<?xml version="1.0" ?>
<robot name="four_wheel_independent_drive_and_steering_vehicle" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <material name="black">
    <color rgba="0.15 0.15 0.15 1.0"/>
  </material>
  <material name="white">
    <color rgba="0.9 0.9 0.9 1.0"/>
  </material>
  <material name="red">
    <color rgba="1.0 0.0 0.0 1.0"/>
  </material>
  <material name="blue">
    <color rgba="0.0 0.0 1.0 1.0"/>
  </material>

  <link name="base_footprint"/>
  
  <link name="base_link"/>
  <joint name="footprint_to_base" type="fixed">
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <parent link="base_footprint"/>
    <child link="base_link"/>
  </joint>

  <link name="body">
    <visual>
      <origin xyz="0 0 0.06" rpy="0 0 0"/>
      <geometry><box size="0.73 0.48 0.12"/></geometry>
      <material name="white"/>
    </visual>
    <visual>
      <origin xyz="0 0 -0.06" rpy="0 0 0"/>
      <geometry><box size="0.50 0.28 0.12"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.73 0.28 0.24"/></geometry>
    </collision>
    <inertial>
      <mass value="30.0"/>
      <inertia ixx="0.72" ixy="0" ixz="0" iyy="1.47" iyz="0" izz="1.90"/>
    </inertial>
  </link>
  
  <joint name="base_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0 0 0.24"/> 
    <parent link="base_link"/>
    <child link="body"/>
  </joint>
  
  <gazebo reference="body">
    <mu1>0.5</mu1> 
    <mu2>0.5</mu2>
    <kp>10000000.0</kp> 
    <kd>1.0</kd>
    <minDepth>0.001</minDepth>
    <material>Gazebo/White</material>
  </gazebo>

  <link name="laser_link">
    <visual>
      <geometry><cylinder length="0.025" radius="0.025"/></geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry><cylinder length="0.025" radius="0.025"/></geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>
  <joint name="laser_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0.3 0 0.13"/> <parent link="body"/>
    <child link="laser_link"/>
  </joint>

  <link name="imu_link">
    <visual>
      <geometry><box size="0.02 0.02 0.01"/></geometry>
      <material name="red"/>
    </visual>
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
  </link>
  <joint name="imu_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0 0 0.12"/>
    <parent link="body"/>
    <child link="imu_link"/>
  </joint>

  <xacro:macro name="wheel_module" params="prefix x_offset y_offset">
    
    <link name="${prefix}_wheel_steer">
      <visual>
        <origin rpy="0 0 0" xyz="0 0 -0.05"/>
        <geometry><box size="0.06 0.04 0.10"/></geometry>
        <material name="black"/>
      </visual>
      <inertial>
        <mass value="1.0"/>
        <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.005"/>
      </inertial>
    </link>
    <joint name="${prefix}_wheel_steer_joint" type="revolute">
      <origin rpy="0 0 0" xyz="${x_offset} ${y_offset} -0.04"/>
      <parent link="body"/>
      <child link="${prefix}_wheel_steer"/>
      <axis xyz="0 0 1"/>
      <limit effort="1000" lower="-3.1416" upper="3.1416" velocity="50"/>
      <dynamics damping="10.0" friction="50.0"/>
    </joint>

    <link name="${prefix}_wheel_rotor">
      <visual>
        <geometry>
          <cylinder length="0.06" radius="0.1015"/>
        </geometry>
        <material name="black"/>
      </visual>
      <collision>
        <geometry>
          <sphere radius="0.1015"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="4.0"/>
        <inertia ixx="0.012" ixy="0" ixz="0" iyy="0.012" iyz="0" izz="0.02"/>
      </inertial>
    </link>
    
    <joint name="${prefix}_wheel_rotor_joint" type="continuous">
      <origin rpy="-1.570796 0 0" xyz="0 0 -0.0985"/> 
      <parent link="${prefix}_wheel_steer"/>
      <child link="${prefix}_wheel_rotor"/>
      <axis xyz="0 0 1"/> 
      <limit effort="10000" velocity="23.5"/> 
      <dynamics damping="1.0" friction="1.0"/>
    </joint>

    <gazebo reference="${prefix}_wheel_rotor">
      <mu1>0.8</mu1> 
      <mu2>0.8</mu2>
      <kp>10000000.0</kp>
      <kd>1.0</kd>
      <minDepth>0.0001</minDepth> 
      <material>Gazebo/DarkGrey</material>
    </gazebo>
  </xacro:macro>

  <xacro:wheel_module prefix="front_left" x_offset="0.24" y_offset="0.19" />
  <xacro:wheel_module prefix="front_right" x_offset="0.24" y_offset="-0.19" />
  <xacro:wheel_module prefix="rear_left" x_offset="-0.24" y_offset="0.19" />
  <xacro:wheel_module prefix="rear_right" x_offset="-0.24" y_offset="-0.19" />

  <gazebo reference="laser_link">
    <sensor name="laser" type="ray">
      <pose>0 0 0 0 0 0</pose>
      <visualize>false</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>800</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.05</min>
          <max>30.0</max>
          <resolution>0.01</resolution>
        </range>
      </ray>
      <plugin filename="libgazebo_ros_ray_sensor.so" name="gazebo_ros_lidar_controller">
        <ros>
          <remapping>~/out:=scan</remapping>
        </ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>laser_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <gazebo reference="imu_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>100</update_rate>
      <visualize>true</visualize>
      <plugin filename="libgazebo_ros_imu_sensor.so" name="gazebo_ros_imu_controller">
        <ros>
          <remapping>~/out:=imu</remapping>
        </ros>
        <frame_name>imu_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <gazebo>
    <plugin filename="libgazebo_ros_p3d.so" name="ground_truth_odometry">
      <always_on>true</always_on>
      <update_rate>30.0</update_rate>
      <ros>
        <remapping>odom:=/groundtruth_odom</remapping>
      </ros>
      <body_name>base_footprint</body_name>
      <frame_name>odom</frame_name>
    </plugin>
  </gazebo>

  <xacro:macro name="control_interface" params="prefix">
    <joint name="${prefix}_wheel_steer_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="${prefix}_wheel_rotor_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </xacro:macro>

  <ros2_control name="GazeboSystem" type="system">
    <hardware>
      <plugin>gazebo_ros2_control/GazeboSystem</plugin>
    </hardware>
    <xacro:control_interface prefix="front_left"/>
    <xacro:control_interface prefix="front_right"/>
    <xacro:control_interface prefix="rear_left"/>
    <xacro:control_interface prefix="rear_right"/>
  </ros2_control>

  <gazebo>
    <plugin filename="libgazebo_ros2_control.so" name="gazebo_ros2_control">
      <robot_param>robot_description</robot_param>
      <robot_param_node>/robot_state_publisher</robot_param_node>
      <parameters>config/fwids_controllers_ros2.yaml</parameters>
    </plugin>
  </gazebo>

</robot>